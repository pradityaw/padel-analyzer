{
  "name": "padel-analyzer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch server/_core/index.ts",
    "build": "vite build --config vite.config.ts && node scripts/esbuild-server.mjs",
    "start": "NODE_ENV=production node dist/index.js",
    "preview": "npm run build && npm run start",
    "typecheck": "tsc --noEmit",
    "qa:browser": "playwright test --config playwright.config.ts",
    "qa:mvp": "npm run typecheck && npm run build && npm run qa:browser",
    "test:contracts": "tsx scripts/qa/analysis-contract.test.ts && tsx scripts/qa/object-storage.test.ts",
    "test:court-calibration": "tsx scripts/qa/court-calibration.test.ts",
    "test:overlay-frame-budget": "tsx scripts/qa/overlay-frame-budget.test.ts",
    "test:mobile-ball-tracking": "tsx mobile/scripts/ball-tracking.test.ts",
    "test:tracking-smoke": "tsx scripts/qa/tracking-integration-smoke.ts",
    "test:cv": "python3 -m pytest scripts/cv/tests -q",
    "cv:doctor": "if [ -x .venv/bin/python3 ]; then .venv/bin/python3 scripts/cv/doctor.py; else python3 scripts/cv/doctor.py; fi",
    "release:beta-gates": "node scripts/release-gates.mjs --skip-build",
    "release:gates": "node scripts/release-gates.mjs",
    "cursor-sdk": "node scripts/cursor-sdk/run.mjs",
    "cursor-sdk:list": "node scripts/cursor-sdk/run.mjs --list",
    "cursor-sdk:watch": "node scripts/cursor-sdk/watch.mjs --watch",
    "cursor-sdk:qa-once": "node scripts/cursor-sdk/watch.mjs --once",
    "cursor-sdk:feedback-review": "node scripts/cursor-sdk/run.mjs --task feedback-review",
    "cursor-sdk:ux-review": "node scripts/cursor-sdk/run.mjs --task ux-review",
    "feedback:collect": "node scripts/feedback-bot/collect.mjs",
    "feedback:triage": "node scripts/feedback-bot/triage.mjs",
    "feedback:dry-run": "node scripts/feedback-bot/triage.mjs --dry-run",
    "feedback:collect-slack": "node scripts/feedback-bot/collect-slack.mjs",
    "feedback:triage-slack": "node scripts/feedback-bot/triage-slack.mjs",
    "feedback:dry-run-slack": "node scripts/feedback-bot/triage-slack.mjs --dry-run",
    "feedback:verify-slack": "node scripts/feedback-bot/verify-slack-setup.mjs",
    "feedback:post-slack-retest": "node scripts/feedback-bot/post-slack-thread.mjs --thread-id burst-1779203975.053489 --text \"PR #13 merged — please retry upload: tap the dashed drop zone, pick a .mp4, and start analysis. If it still fails, reply with device + browser, exact error banner text, and Network tab status for POST /api/upload.\"",
    "feedback:pin-slack-template": "node scripts/feedback-bot/post-slack-thread.mjs --channel --text \"Bug report (copy/paste):\\n• What I did: …\\n• Expected: …\\n• Actual: … (exact error text)\\n• Device: e.g. iPhone / Safari, Android / Chrome, or Expo Go\\n• Screenshot or screen recording if possible\\n\\nSee docs/feedback-slack-templates.md in the repo.\"",
    "feedback:sync-dev": "node -e \"import('./scripts/feedback-bot/lib/sync-dev-workspace.mjs').then(m=>m.syncDevWorkspace()).then(r=>console.log(r))\"",
    "daemon:start": "pm2 start ecosystem.config.cjs",
    "daemon:stop": "pm2 stop ecosystem.config.cjs",
    "daemon:restart": "pm2 restart ecosystem.config.cjs",
    "daemon:status": "pm2 status",
    "daemon:logs": "pm2 logs",
    "daemon:save": "pm2 save",
    "daemon:startup": "pm2 startup",
    "dev:mobile": "node scripts/dev-with-mobile.mjs",
    "mobile:start": "npm --prefix mobile start",
    "mobile:start:live": "npm --prefix mobile run start:live",
    "mobile:typecheck": "npm --prefix mobile run typecheck",
    "mobile:doctor": "npm --prefix mobile run doctor",
    "mobile:ios:prebuild": "bash ./scripts/ios-prebuild.sh",
    "mobile:ios:build": "bash ./scripts/ios-build.sh",
    "mobile:ios:test": "bash ./scripts/ios-test.sh",
    "mobile:ios:setup-tests": "npm --prefix mobile run ios:setup-tests",
    "mobile:ios:qa": "npm run mobile:ios:prebuild && npm run mobile:ios:setup-tests && npm run mobile:ios:build && npm run mobile:ios:test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "feedback:test-slack-utils": "node scripts/feedback-bot/test-slack-utils.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1053.0",
    "@aws-sdk/s3-request-presigner": "^3.1053.0",
    "@cursor/sdk": "^1.0.11",
    "@mediapipe/tasks-vision": "^0.10.18",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-slider": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toggle": "^1.1.2",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@tanstack/react-query": "^5.72.2",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "better-sqlite3": "^11.8.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cookie": "^1.0.2",
    "drizzle-orm": "^0.39.3",
    "express": "^5.1.0",
    "framer-motion": "^12.6.3",
    "lucide-react": "^0.475.0",
    "multer": "^2.1.1",
    "onnxruntime-web": "^1.24.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "recharts": "^2.15.1",
    "superjson": "^2.2.2",
    "tailwind-merge": "^3.0.2",
    "wouter": "^3.7.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.1.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cookie": "^1.0.0",
    "@types/express": "^5.0.2",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.14.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.1",
    "drizzle-kit": "^0.30.5",
    "esbuild": "^0.25.2",
    "pm2": "^6.0.14",
    "tailwindcss": "^4.1.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vite": "^6.3.1"
  }
}
