# Copy to .env.feedback at repo root (gitignored). Do not commit real values.

# Slack (required for collect/triage-slack)
SLACK_BOT_TOKEN=xoxb-...
SLACK_FEEDBACK_CHANNEL_ID=C...
# Comma-separated Slack member IDs (U...); strongly recommended
SLACK_ALLOWLIST_USER_IDS=U...

# Cursor cloud agents (required for triage-slack)
CURSOR_API_KEY=...

# Repo cloned by cloud agent (optional; default is padel-analyzer on GitHub)
FEEDBACK_REPO_URL=https://github.com/pradityaw/padel-analyzer.git

# Spend caps — use low values while testing
FEEDBACK_MAX_PRS_PER_RUN=1
FEEDBACK_MAX_MESSAGES_PER_RUN=20
FEEDBACK_MODEL=composer-2
FEEDBACK_AGENT_TIMEOUT_MS=1200000

# Squash-merge feedback PRs into the default branch (also via GitHub Action on PR open)
FEEDBACK_AUTO_MERGE=1
# GITHUB_TOKEN=ghp_...   # repo: contents + pull_requests write

# Telegram (optional; for feedback:collect / feedback:triage)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_FEEDBACK_CHAT_ID=
# TELEGRAM_ALLOWLIST_USER_IDS=
