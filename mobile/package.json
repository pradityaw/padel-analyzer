{
  "name": "padel-analyzer-mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "start:live": "node scripts/expo-live.mjs",
    "android": "expo run:android",
    "ios": "env DEVELOPER_DIR=/Applications/Xcode.app/Contents/Developer expo start --ios",
    "ios:prebuild": "bash ../scripts/ios-prebuild.sh",
    "ios:prebuild:clean": "bash ../scripts/ios-prebuild.sh --clean",
    "ios:setup-tests": "node scripts/setup-ios-test-targets.mjs",
    "ios:build": "bash ../scripts/ios-build.sh",
    "ios:test": "bash ../scripts/ios-test.sh",
    "ios:qa": "npm run ios:prebuild && npm run ios:setup-tests && npm run ios:build && npm run ios:test",
    "web": "expo start --web",
    "doctor": "expo-doctor",
    "typecheck": "tsc --noEmit",
    "test:ball-tracking": "tsx scripts/ball-tracking.test.ts"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.10",
    "@sentry/react-native": "~7.2.0",
    "@tanstack/react-query": "^5.97.0",
    "@trpc/client": "^11.16.0",
    "expo": "~54.0.34",
    "expo-av": "~16.0.8",
    "expo-camera": "~17.0.10",
    "expo-document-picker": "~14.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-worklets": "0.5.1",
    "superjson": "^2.2.6"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "babel-preset-expo": "~54.0.10",
    "expo-doctor": "^1.18.18",
    "typescript": "~5.9.2",
    "xcode": "^3.0.1"
  },
  "private": true
}
